# Copy to .env on the server and fill in values:
#   cp .env.production.example .env
# Generate AUTH_SECRET with: openssl rand -base64 32

# ---- Public URL / reverse proxy ----
DOMAIN=example.com
NEXTAUTH_URL=https://example.com

# ---- NextAuth ----
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
ALLOWED_EMAIL_DOMAIN=innowise.com

# ---- AI / Google ----
GEMINI_API_KEY=
# Optional: override the Gemini model (e.g. if the default preview model is
# overloaded/deprecated). Leave empty to use the built-in default.
GEMINI_MODEL=
GOOGLE_DRIVE_PDP_FOLDER_ID=
# Optional default guest auto-invited to every assessment Meet event.
# Each assessment may also override this via its own optionalGuestEmail field.
# Leave empty to disable.
OPTIONAL_MEETING_GUEST_EMAIL=

# ---- Cron ----
# Shared secret for the nightly "Topic of the day" job. The docker-compose
# `cron` service sends it as a Bearer token to /api/cron/daily-topic.
# Generate with: openssl rand -base64 32
CRON_SECRET=

# ---- Email notifications (Resend) ----
# Get a key at https://resend.com (free tier: 3k/mo). Leave RESEND_API_KEY
# empty to disable email; in-app notifications still work.
# EMAIL_FROM must use a domain verified in Resend (or its onboarding@resend.dev
# sandbox address for testing).
RESEND_API_KEY=
EMAIL_FROM="Node Assessment <notifications@example.com>"

# ---- Postgres ----
POSTGRES_USER=pdp
POSTGRES_PASSWORD=change-me
POSTGRES_DB=pdp
DATABASE_URL=postgresql://pdp:change-me@db:5432/pdp

# ENABLE_DEV_LOGIN intentionally unset in production.
