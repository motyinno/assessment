# Copy to .env on the server and fill in values:
#   cp .env.production.example .env
# Generate AUTH_SECRET with: openssl rand -base64 32

# ---- Public URL / reverse proxy ----
DOMAIN=example.com
NEXTAUTH_URL=https://example.com

# ---- NextAuth ----
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
ALLOWED_EMAIL_DOMAIN=innowise.com

# ---- AI / Google ----
GEMINI_API_KEY=
GOOGLE_DRIVE_PDP_FOLDER_ID=

# ---- Postgres ----
POSTGRES_USER=pdp
POSTGRES_PASSWORD=change-me
POSTGRES_DB=pdp
DATABASE_URL=postgresql://pdp:change-me@db:5432/pdp

# ENABLE_DEV_LOGIN intentionally unset in production.
