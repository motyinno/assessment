datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ---- Enums ----
//
// Grade values like "jun-", "jun+" contain non-identifier characters that are
// not valid for Postgres native enums; grade therefore stays as a String,
// validated at the API edge via Zod (see lib/schemas.ts).

enum UserRole {
  USER
  ASSESSOR
  MANAGER
  ADMIN
}

enum AssessmentStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AssessmentReviewStatus {
  NONE // default — not submitted for admin review
  PENDING // assessor ended the assessment; awaiting admin decision
  REVIEWED // admin recorded an upgrade / no-upgrade decision
}

enum AssessmentTypeEnum {
  GENERAL
  PDP_CHECK
}

enum ParticipantRole {
  SUBJECT
  ASSESSOR
}

enum SessionType {
  TECHNICAL_1
  TECHNICAL_2
  TECHNICAL_3
  PDP_TECH
}

enum SessionStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum PdpStatus {
  GENERATING
  ON_REVIEW
  DRAFT
  ACTIVE
  COMPLETED
  FAILED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// A single task inside a PDP. THEORY items are checked verbally / via a written
// note; PRACTICE items require a link to the implementation (enforced at the
// API edge, see lib/schemas.ts).
enum PdpItemType {
  THEORY
  PRACTICE
}

enum PdpItemStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED // employee sent it for the reviewer's check
  VERIFIED // reviewer accepted it
  REWORK // reviewer sent it back with a comment
}

enum NotificationType {
  REQUEST_SUBMITTED // -> admins: a user requested an assessment
  ASSESSMENT_ASSIGNED // -> assessor: assigned to an assessment
  REQUEST_APPROVED // -> requester: request approved
  REQUEST_REJECTED // -> requester: request rejected
  PDP_ITEM_SUBMITTED // -> reviewer: an employee submitted a PDP item for review
  PDP_ITEM_REVIEWED // -> employee: reviewer verified or sent back a PDP item
  PDP_COMPLETED // -> employee: all PDP items verified; plan is closed
}

// ---- Models ----

model User {
  id                    String    @id @default(cuid())
  name                  String
  email                 String    @unique
  role                  UserRole  @default(USER)
  grade                 String? // "jun-" / "jun" / "jun+" / "mid-" / ... see lib/grades.ts
  project               String?
  isArchived            Boolean   @default(false) // left the department; kept for historical assessments
  managerId             String?
  googleAccessToken     String?
  googleRefreshToken    String?
  googleTokenExpiresAt  DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  manager              User?                       @relation("manages", fields: [managerId], references: [id], onDelete: SetNull)
  reports              User[]                      @relation("manages")
  participations       AssessmentParticipant[]
  pdps                 Pdp[]
  createdPdps          Pdp[]                       @relation("createdPdps")
  reviewedAssessments  Assessment[]                @relation("reviewedAssessments")
  requestedAssessments AssessmentRequest[]         @relation("requestedBy")
  requestAssessors     AssessmentRequestAssessor[]
  apiTokens            ApiToken[]
  notifications        Notification[]
  certificates         Certificate[]
  reviewableItems      PdpItem[]                   @relation("pdpItemReviewer")

  @@index([managerId])
}

/// A certificate a user adds to their profile. Stored as the bare code
/// (e.g. "5Y0FT4E8X7GG9F6T"); the public verification URL is derived as
/// `${CERT_VERIFY_BASE_URL}${code}` (see lib/certificates.ts).
model Certificate {
  id        String   @id @default(cuid())
  userId    String
  code      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, code])
  @@index([userId])
}

/// Personal access tokens for programmatic API access (no Google OAuth).
/// Only the SHA-256 hash is stored. Token inherits the owning user's role/permissions.
model ApiToken {
  id          String    @id @default(cuid())
  userId      String
  name        String
  tokenHash   String    @unique
  tokenPrefix String
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Assessment {
  id                 String             @id @default(cuid())
  title              String
  status             AssessmentStatus   @default(PLANNED)
  assessmentType     AssessmentTypeEnum @default(GENERAL)
  grade              String
  scheduledAt        DateTime?
  completedAt        DateTime?
  notes              String?
  aiFeedback         String?
  pdpTopics          Json?
  // Admin review of a finished assessment: the assessor "ends" it (PENDING),
  // then an admin decides whether to upgrade the subject's grade (REVIEWED).
  reviewStatus         AssessmentReviewStatus @default(NONE)
  submittedForReviewAt DateTime?
  reviewedAt           DateTime?
  reviewedById         String?
  reviewNotes          String?
  gradeUpgraded        Boolean                @default(false)
  previousGrade        String? // subject grade captured at decision time (audit)
  newGrade             String? // chosen grade when upgraded (audit)
  // Admin-only cancellation with a mandatory reason.
  cancellationReason   String?
  cancelledAt          DateTime?
  cancelledById        String?
  /// Optional Google Calendar guest auto-invited to every Meet for this
  /// assessment. Falls back to OPTIONAL_MEETING_GUEST_EMAIL env var when
  /// unset. Empty string and null both mean "no guest".
  optionalGuestEmail String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  participants    AssessmentParticipant[]
  results         AssessmentResult[]
  selfAssessments SelfAssessment[]
  pdps            Pdp[]
  sessions        AssessmentSession[]
  request         AssessmentRequest?
  reviewedBy      User?                   @relation("reviewedAssessments", fields: [reviewedById], references: [id])

  @@index([reviewStatus])
}

model AssessmentParticipant {
  id               String          @id @default(cuid())
  assessmentId     String
  userId           String
  participantRole  ParticipantRole
  assignedSections Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@unique([assessmentId, userId, participantRole])
  @@index([userId])
}

model AssessmentResult {
  id           String   @id @default(cuid())
  assessmentId String
  category     String
  score        Float?
  comment      String?
  subtopics    Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, category])
}

model Pdp {
  id           String    @id @default(cuid())
  userId       String
  createdById  String?
  assessmentId String?
  fileName     String
  driveFileId  String?
  driveLink    String?
  status       PdpStatus @default(DRAFT)
  error        String?
  reviewNotes  String?
  topicsJson   Json
  startedAt    DateTime  @default(now())
  createdAt    DateTime  @default(now())

  user       User        @relation(fields: [userId], references: [id])
  createdBy  User?       @relation("createdPdps", fields: [createdById], references: [id])
  assessment Assessment? @relation(fields: [assessmentId], references: [id])
  items      PdpItem[]

  @@index([userId])
  @@index([assessmentId])
  @@index([status])
}

/// A single theory question or practical task derived from a PDP's topics at
/// generation time. The employee works through each item and submits it; the
/// reviewer (the employee's manager, captured in `reviewerId`) verifies it or
/// sends it back. When every item is VERIFIED the parent Pdp is closed
/// (status COMPLETED).
model PdpItem {
  id            String        @id @default(cuid())
  pdpId         String
  type          PdpItemType
  category      String // source topic/category, used to group items in the UI
  title         String // the question text or the practical task description
  order         Int
  status        PdpItemStatus @default(NOT_STARTED)
  evidenceLink  String? // PRACTICE: link to the implementation (PR / demo / doc)
  evidenceNote  String? // THEORY: optional written answer / notes
  submittedAt   DateTime?
  reviewerId    String? // snapshot of the employee's manager at generation time
  reviewedAt    DateTime?
  reviewComment String? // reviewer feedback / mandatory reason on REWORK
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  pdp      Pdp   @relation(fields: [pdpId], references: [id], onDelete: Cascade)
  reviewer User? @relation("pdpItemReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([pdpId])
  @@index([reviewerId, status])
}

model AssessmentRequest {
  id             String             @id @default(cuid())
  userId         String
  status         RequestStatus      @default(PENDING)
  assessmentType AssessmentTypeEnum @default(GENERAL)
  grade          String
  notes          String?
  adminNotes     String?
  assessmentId   String?            @unique
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  user       User                        @relation("requestedBy", fields: [userId], references: [id])
  assessment Assessment?                 @relation(fields: [assessmentId], references: [id])
  assessors  AssessmentRequestAssessor[]
}

/**
 * Many-to-many between AssessmentRequest and User (the assigned assessors).
 * Replaces the old `AssessmentRequest.assessorId` (singular FK) +
 * `AssessmentRequest.assessorIds` (JSON array, no FK enforcement) pair so we
 * get proper foreign-key guarantees and queryability.
 */
model AssessmentRequestAssessor {
  id         String   @id @default(cuid())
  requestId  String
  assessorId String
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  request  AssessmentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  assessor User              @relation(fields: [assessorId], references: [id])

  @@unique([requestId, assessorId])
  @@index([assessorId])
}

model AssessmentSession {
  id                 String        @id @default(cuid())
  assessmentId       String
  type               SessionType
  status             SessionStatus @default(NOT_STARTED)
  order              Int
  durationMin        Int           @default(60)
  assessorId         String?
  assessorName       String?
  scheduledAt        DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  notes              String?
  meetingLink        String?
  calendarEventId    String?
  meetingScheduledAt DateTime?
  recordingLink      String?
  recordingFileId    String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, type])
}

/// In-app notification for a single recipient. Mirrored to email on creation
/// (best-effort) so recipients are reached even when the app is closed.
model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  /// Relative in-app link to the related request/assessment.
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model SelfAssessment {
  id           String   @id @default(cuid())
  assessmentId String
  sectionId    String
  topicId      String
  score        Int? // 0-10 self rating; range enforced at API edge
  comment      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, topicId])
}
