datasource db {
  provider = "sqlite"
  url      = "file:../data/pdp.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  hashedPassword String
  role           String   @default("USER") // "USER" | "ASSESSOR" | "ADMIN"
  grade          String? // "jun" | "mid" | "sen"
  project        String?
  manager                String?
  softAiInterviewPassed  Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  participations      AssessmentParticipant[]
  pdps                Pdp[]
  requestedAssessments AssessmentRequest[] @relation("requestedBy")
  assignedAssessments  AssessmentRequest[] @relation("assignedAssessor")
}

model Assessment {
  id          String    @id @default(cuid())
  title       String
  status      String    @default("PLANNED") // PLANNED | IN_PROGRESS | COMPLETED | CANCELLED
  grade       String // "jun" | "mid" | "sen"
  scheduledAt DateTime?
  completedAt DateTime?
  notes       String?
  aiFeedback  String?   // AI-generated general feedback
  pdpTopics   String?   // JSON string of AI-generated PDP topics
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  participants    AssessmentParticipant[]
  results         AssessmentResult[]
  selfAssessments SelfAssessment[]
  pdps            Pdp[]
  sessions        AssessmentSession[]
  request         AssessmentRequest?
}

model AssessmentParticipant {
  id              String   @id @default(cuid())
  assessmentId    String
  userId          String
  participantRole String // "SUBJECT" | "ASSESSOR"
  assignedSections String? // JSON array of section names
  createdAt       DateTime @default(now())

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@unique([assessmentId, userId, participantRole])
}

model AssessmentResult {
  id           String  @id @default(cuid())
  assessmentId String
  category     String
  score        Float?
  comment      String?
  subtopics    String? // JSON array

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, category])
}

model Pdp {
  id           String   @id @default(cuid())
  userId       String
  assessmentId String?
  fileName     String
  filePath     String
  status       String   @default("DRAFT") // DRAFT | ACTIVE | COMPLETED
  topicsJson   String
  createdAt    DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id])
  assessment Assessment? @relation(fields: [assessmentId], references: [id])
}

model AssessmentRequest {
  id           String   @id @default(cuid())
  userId       String
  status       String   @default("PENDING") // PENDING | APPROVED | REJECTED
  grade        String // "jun" | "mid" | "sen"
  notes        String?
  adminNotes   String?
  assessorId   String? // primary assessor (backward compat)
  assessorIds  String? // JSON array of all assessor IDs
  assessmentId String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User        @relation("requestedBy", fields: [userId], references: [id])
  assessor   User?       @relation("assignedAssessor", fields: [assessorId], references: [id])
  assessment Assessment? @relation(fields: [assessmentId], references: [id])
}

model AssessmentSession {
  id           String    @id @default(cuid())
  assessmentId String
  type         String // SOFT_AI | TECHNICAL_1 | TECHNICAL_2 | TECHNICAL_3
  status       String    @default("NOT_STARTED") // NOT_STARTED | IN_PROGRESS | COMPLETED | SKIPPED
  order        Int
  durationMin  Int       @default(60)
  assessorId   String? // кто проводил эту сессию
  assessorName String? // имя асессора (snapshot на момент проведения)
  scheduledAt  DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, type])
}

model SelfAssessment {
  id           String @id @default(cuid())
  assessmentId String
  sectionId    String // tech matrix section id (e.g. "js", "typescript")
  topicId      String // tech matrix topic id (e.g. "async-programming")
  score        Int?   // 1-5 self rating
  comment      String?

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, topicId])
}
